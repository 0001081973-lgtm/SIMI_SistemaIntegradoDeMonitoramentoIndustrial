<Window x:Class="SensorInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIMI — Sistema Integrado de Monitoramento Industrial"
        Height="620" Width="920"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueStyle">
            <Setter Property="Foreground" Value="#89DCEB"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#313244"/>
            <Setter Property="AlternatingRowBackground" Value="#1E1E2E"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#45475A"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⚙ SIMI — Monitoramento Industrial"
                       FontSize="22" FontWeight="Bold" Foreground="#CBA6F7"/>
            <TextBlock Text="Sistema Integrado de Sensores · Temperatura · Pressão · Umidade · Vibração"
                       FontSize="12" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Painel de estatísticas -->
        <Border Grid.Row="1" Background="#313244" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="TOTAL DE REGISTROS" Style="{StaticResource LabelStyle}" FontSize="11"/>
                    <TextBlock Text="{Binding TotalRegistros}" Style="{StaticResource ValueStyle}" FontSize="24"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="MÉDIA TEMPERATURA (°C)" Style="{StaticResource LabelStyle}" FontSize="11"/>
                    <TextBlock Text="{Binding MediaTemperatura, StringFormat={}{0:F2}}" Style="{StaticResource ValueStyle}" FontSize="24"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="MÉDIA VIBRAÇÃO (m/s²)" Style="{StaticResource LabelStyle}" FontSize="11"/>
                    <TextBlock Text="{Binding MediaVibracao, StringFormat={}{0:F2}}" Style="{StaticResource ValueStyle}" FontSize="24"/>
                </StackPanel>

                <Button Grid.Column="3" Content="↻  Carregar Dados"
                        Command="{Binding CarregarSensoresCommand}"
                        Style="{StaticResource PrimaryBtn}" Margin="12,0,8,0"/>

                <Button Grid.Column="4" Content="✕  Limpar"
                        Command="{Binding LimparCommand}"
                        Style="{StaticResource SecondaryBtn}"/>
            </Grid>
        </Border>

        <!-- Tabela de dados -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Sensores}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="60"/>
                <DataGridTextColumn Header="Temperatura (°C)" Binding="{Binding Temperatura, StringFormat={}{0:F2}}" Width="*"/>
                <DataGridTextColumn Header="Pressão (bar)"    Binding="{Binding Pressao,    StringFormat={}{0:F2}}" Width="*"/>
                <DataGridTextColumn Header="Umidade (%)"      Binding="{Binding Umidade,    StringFormat={}{0:F1}}" Width="*"/>
                <DataGridTextColumn Header="Vibração (m/s²)"  Binding="{Binding Vibracao,   StringFormat={}{0:F2}}" Width="*"/>
                <DataGridTextColumn Header="Origem"           Binding="{Binding Origem}"    Width="100"/>
                <DataGridTextColumn Header="Timestamp"        Binding="{Binding Timestamp, StringFormat={}{0:dd/MM/yy HH:mm:ss}}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Barra de status -->
        <Border Grid.Row="3" Background="#313244" CornerRadius="6"
                Padding="12,8" Margin="0,12,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#A6E3A1" FontSize="12"/>
        </Border>
    </Grid>
</Window>
